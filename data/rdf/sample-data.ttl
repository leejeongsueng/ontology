@prefix lib: <http://example.org/library#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

<http://example.org/library-data> a owl:Ontology ;
    owl:imports <http://example.org/library> .

# 장르 데이터
lib:장르_디스토피아 a lib:Genre .
lib:장르_소설 a lib:Genre .
lib:장르_과학 a lib:Genre .

# 위치 데이터
lib:층_1 a lib:Floor .
lib:층_2 a lib:Floor .

lib:서가_A1 a lib:Shelf ;
    lib:within lib:층_1 .
lib:서가_B2 a lib:Shelf ;
    lib:within lib:층_2 .

# 출판사 데이터
lib:출판사_세커앤워버그 a lib:Publisher ;
    lib:name "세커 앤 워버그" .

lib:출판사_채토앤윈더스 a lib:Publisher ;
    lib:name "채토 앤 윈더스" .

lib:출판사_MIT프레스 a lib:Publisher ;
    lib:name "MIT 프레스" .

# 저자 데이터
lib:저자_조지오웰 a lib:Author ;
    lib:name "조지 오웰" .

lib:저자_올더스헉슬리 a lib:Author ;
    lib:name "올더스 헉슬리" .

lib:저자_마빈민스키 a lib:Author ;
    lib:name "마빈 민스키" .

# 자료 데이터 (도서, 전자책, 멀티미디어)
lib:도서_1984 a lib:Book ;
    lib:title "1984" ;
    lib:hasAuthor lib:저자_조지오웰 ;
    lib:isbn "978-0451524935" ;
    lib:hasGenre lib:장르_디스토피아 ;
    lib:publishedBy lib:출판사_세커앤워버그 ;
    lib:isRelatedTo lib:도서_멋진신세계 ;
    lib:locatedAt lib:서가_A1 .

lib:도서_멋진신세계 a lib:Book ;
    lib:title "멋진 신세계" ;
    lib:hasAuthor lib:저자_올더스헉슬리 ;
    lib:isbn "978-0060850524" ;
    lib:hasGenre lib:장르_디스토피아 ;
    lib:publishedBy lib:출판사_채토앤윈더스 ;
    lib:locatedAt lib:서가_A1 .

lib:전자책_마음의사회 a lib:EBook ;
    lib:title "마음의 사회" ;
    lib:hasAuthor lib:저자_마빈민스키 ;
    lib:hasGenre lib:장르_과학 ;
    lib:publishedBy lib:출판사_MIT프레스 .

lib:멀티미디어_AI다큐멘터리 a lib:Multimedia ;
    lib:title "AI: 미래" ;
    lib:hasAuthor lib:저자_마빈민스키 ;
    lib:locatedAt lib:서가_B2 .

# 이용자 데이터
lib:이용자_앨리스 a lib:Student ;
    lib:name "앨리스 김" .

lib:이용자_밥 a lib:Staff ;
    lib:name "밥 리" .

# 대출 데이터
lib:대출_001 a lib:Loan ;
    lib:loanedResource lib:도서_1984 ;
    lib:borrowedBy lib:이용자_앨리스 ;
    lib:loanDate "2024-03-01T10:00:00"^^xsd:dateTime .

# 예약 데이터
lib:예약_001 a lib:Reservation ;
    lib:reservedResource lib:전자책_마음의사회 ;
    lib:reservedBy lib:이용자_밥 .
